# PostgreSQL 数据库连接
DATABASE_URL="postgresql://用户名:密码@localhost:5432/tbtparent_me?schema=public"

# MinIO 对象存储配置
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_USE_SSL="false"
MINIO_ACCESS_KEY="your-access-key"
MINIO_SECRET_KEY="your-secret-key"
MINIO_BUCKET="tbtparent-me"

# 管理后台密钥（用于简单鉴权）
ADMIN_SECRET="your-admin-secret-change-this"
