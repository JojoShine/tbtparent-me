generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Home {
  id        Int      @id @default(1)
  name_zh   String
  name_en   String
  nameZh    String
  title_zh  String
  title_en  String
  bio_zh    String
  bio_en    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SocialLink {
  id        Int      @id @default(autoincrement())
  name      String
  url       String
  icon      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id             Int      @id @default(autoincrement())
  name_zh        String
  name_en        String
  description_zh String
  description_en String
  tags_zh        String[]
  tags_en        String[]
  deadline_zh    String
  deadline_en    String
  link           String
  github         String?
  demo_url       String?
  project_type   String   @default("pc")
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  content_en     String?
  content_zh     String?
  recent_focus   Boolean  @default(false)
  video_url      String?
}

model Blog {
  id           Int         @id @default(autoincrement())
  title_zh     String
  title_en     String
  slug         String      @unique
  excerpt_zh   String
  excerpt_en   String
  content_zh   String
  content_en   String
  status       String      @default("draft")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  pinned       Boolean     @default(false)
  cover_image  String?
  published_at DateTime?
  tags_en      String[]    @default([])
  tags_zh      String[]    @default([])
  images       BlogImage[]
}

model BlogImage {
  id        Int      @id @default(autoincrement())
  blogId    Int
  url       String
  filename  String
  createdAt DateTime @default(now())
  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
}

model About {
  id        Int      @id @default(1)
  bio_zh    String
  bio_en    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TechStack {
  id        Int      @id @default(autoincrement())
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model Tool {
  id             Int      @id @default(autoincrement())
  name_zh        String
  name_en        String
  description_zh String
  description_en String
  link           String
  available      Boolean  @default(false)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ArchiveVideo {
  id             Int       @id @default(autoincrement())
  title_zh       String
  title_en       String
  description_zh String?
  description_en String?
  cover_url      String?
  video_url      String?
  sortOrder      Int       @default(0)
  published_at   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model ArchiveNovel {
  id             Int            @id @default(autoincrement())
  title_zh       String
  title_en       String
  description_zh String?
  description_en String?
  cover_url      String?
  external_link  String?
  sortOrder      Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  status         String         @default("ongoing")
  chapters       NovelChapter[]
}

model NovelChapter {
  id             Int          @id @default(autoincrement())
  novelId        Int
  title_zh       String
  title_en       String
  content_zh     String
  content_en     String?
  sortOrder      Int          @default(0)
  published_at   DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  chapter_number Int
  novel          ArchiveNovel @relation(fields: [novelId], references: [id], onDelete: Cascade)
}

model ArchiveInterview {
  id           Int       @id @default(autoincrement())
  title_zh     String
  title_en     String
  summary_zh   String?
  summary_en   String?
  link         String
  published_at DateTime?
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  cover_url    String?
}

model ArchiveHighlight {
  id             Int       @id @default(autoincrement())
  title_zh       String
  title_en       String
  description_zh String?
  description_en String?
  cover_url      String?
  video_url      String?
  published_at   DateTime?
  sortOrder      Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model QA {
  id         Int      @id @default(autoincrement())
  title_zh   String
  title_en   String
  tags_zh    String[]
  tags_en    String[]
  content_zh String
  content_en String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SiteVisit {
  id        Int      @id @default(autoincrement())
  date      String   @unique
  count     Int      @default(0)
  createdAt DateTime @default(now())
}

model Visitor {
  id              Int      @id @default(autoincrement())
  visitor_id      String   @unique
  visit_dates     String[]
  first_visit_date String?
  last_visit_date  String?
  total_visits     Int      @default(1)
  position         Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
