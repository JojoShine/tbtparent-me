// Prisma Schema - tbtparent.me

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========== 首页 ==========
model Home {
  id        Int      @id @default(1)
  name_zh   String
  name_en   String
  nameZh    String
  title_zh  String
  title_en  String
  bio_zh    String   @db.Text
  bio_en    String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ========== 社交链接 ==========
model SocialLink {
  id        Int      @id @default(autoincrement())
  name      String
  url       String
  icon      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ========== 项目 ==========
model Project {
  id             Int      @id @default(autoincrement())
  name_zh        String
  name_en        String
  description_zh String   @db.Text
  description_en String   @db.Text
  content_zh     String?  @db.Text
  content_en     String?  @db.Text
  tags_zh        String[]
  tags_en        String[]
  deadline_zh    String
  deadline_en    String
  link           String
  github         String?
  demo_url       String?
  project_type   String   @default("pc") // mobile, pc, dashboard
  recent_focus   Boolean  @default(false) // 近期聚焦标识
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ========== 博客 ==========
model Blog {
  id           Int          @id @default(autoincrement())
  title_zh     String
  title_en     String
  slug         String       @unique
  excerpt_zh   String       @db.Text
  excerpt_en   String       @db.Text
  content_zh   String       @db.Text
  content_en   String       @db.Text
  tags_zh      String[]     @default([])
  tags_en      String[]     @default([])
  cover_image  String?
  published_at DateTime?
  status       String       @default("draft")
  pinned       Boolean      @default(false)  // 置顶标记
  images       BlogImage[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

// ========== 博客图片（MinIO） ==========
model BlogImage {
  id        Int      @id @default(autoincrement())
  blogId    Int
  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  url       String
  filename  String
  createdAt DateTime @default(now())
}

// ========== 关于 ==========
model About {
  id        Int      @id @default(1)
  bio_zh    String   @db.Text
  bio_en    String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ========== 技术栈 ==========
model TechStack {
  id        Int      @id @default(autoincrement())
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

// ========== 工具 ==========
model Tool {
  id          Int      @id @default(autoincrement())
  name_zh     String
  name_en     String
  description_zh String @db.Text
  description_en String @db.Text
  link        String
  available   Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ========== 收录 - 视频创作 ==========
model ArchiveVideo {
  id          Int      @id @default(autoincrement())
  title_zh    String
  title_en    String
  description_zh String? @db.Text
  description_en String? @db.Text
  cover_url   String?
  video_url   String?
  sortOrder   Int      @default(0)
  published_at DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ========== 收录 - 小说作品 ==========
model ArchiveNovel {
  id          Int      @id @default(autoincrement())
  title_zh    String
  title_en    String
  description_zh String? @db.Text
  description_en String? @db.Text
  cover_url   String?
  external_link String?
  status      String   @default("ongoing") // ongoing: 连载中, completed: 已完结, discontinued: 停更
  sortOrder   Int      @default(0)
  chapters    NovelChapter[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ========== 收录 - 小说章节 ==========
model NovelChapter {
  id          Int      @id @default(autoincrement())
  novelId     Int
  novel       ArchiveNovel @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapter_number Int   // 章节序号
  title_zh    String
  title_en    String
  content_zh  String   @db.Text
  content_en  String?  @db.Text
  sortOrder   Int      @default(0)
  published_at DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ========== 收录 - 采访报道 ==========
model ArchiveInterview {
  id          Int      @id @default(autoincrement())
  title_zh    String
  title_en    String
  summary_zh  String?  @db.Text
  summary_en  String?  @db.Text
  cover_url   String?
  link        String
  published_at DateTime?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ========== 收录 - 王者集锦 ==========
model ArchiveHighlight {
  id          Int      @id @default(autoincrement())
  title_zh    String
  title_en    String
  description_zh String? @db.Text
  description_en String? @db.Text
  cover_url   String?
  video_url   String?
  published_at DateTime?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ========== 问题集 Q&A ==========
model QA {
  id          Int      @id @default(autoincrement())
  title_zh    String
  title_en    String
  tags_zh     String[] // 标签数组
  tags_en     String[]
  content_zh  String   @db.Text // Markdown 内容
  content_en  String?  @db.Text
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
